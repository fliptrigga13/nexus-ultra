    {
      "name": "Hub Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["nexus_hub_server.py"],
      "port": 7702
    },
    {
      "name": "Swarm Loop",
      "runtimeExecutable": "python",
      "runtimeArgs": ["nexus_swarm_loop.py"],
      "port": 0
    },
    {
      "name": "Cognitive Engine",
      "runtimeExecutable": "python",
      "runtimeArgs": ["nexus_cognitive_engine.py"],
      "port": 0
    },
    {
      "name": "PSO Swarm Brain (Julia GPU)",
      "runtimeExecutable": "julia",
      "runtimeArgs": ["local-scripts/pso_swarm.jl"],
      "port": 7700
    }
  ]
